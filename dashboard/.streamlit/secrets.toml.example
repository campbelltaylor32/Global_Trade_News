# Copy this file to secrets.toml and fill in real values.
# secrets.toml is in .gitignore — never commit credentials.

[db]
user = "YOUR_USER"
password = "YOUR_PASSWORD"
host = "YOUR_HOST"
port = 3306
name = "comtrade"

# Alternatively you can specify a full SQLAlchemy URL instead of the fields above:
# url = "mysql+pymysql://user:URL_ENCODED_PASSWORD@host:3306/comtrade"
