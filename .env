DB_USER=class_user
DB_PASS='CLOU_!@#'
DB_HOST=35.254.120.209
DB_PORT=3306
DB_NAME=comtrade

# ─── Date window for THIS run (YYYY-MM-DD) ────────────────────────────
# GDELT 2.0 starts Feb 18, 2015.  You can iterate this in monthly slices
# by editing and re-running; the manifest dedupes across runs.
START_DATE=2025-01-01
END_DATE=2025-12-31

# ─── Search term filtering ────────────────────────────────────────────
# Only terms with priority <= MAX_PRIORITY are queried.  Curated terms
# are priority 1; extracted single-word terms are priority 3; extracted
# multi-word phrases are priority 4.  Start with 2 to test, raise to 4
# for full coverage.
MAX_PRIORITY=2
TERM_LANGUAGE=en

# ─── GDELT DOC API tuning ─────────────────────────────────────────────
MAX_RECORDS=250          # GDELT cap per query     # Pause between calls (be polite)
RETRY_ATTEMPTS=3

SLEEP_SECONDS=10
MIN_SLEEP_SECONDS=10
GDELT_TIMEOUT_SECONDS=60
RETRY_BACKOFFS=10,20,30
RATE_LIMIT_BACKOFFS=10,20,30

# ─── Daily call ceiling (safety, not a GDELT-enforced limit) ──────────
MAX_DAILY_CALLS=2000

# ─── Events (GDELT 2.0 bulk CSV — bandwidth-heavy, off by default) ────
COLLECT_EVENTS=true
MAX_EVENT_FILES=30       # one file per day; longer windows skip noon-only

# ─── Output ───────────────────────────────────────────────────────────
OUTPUT_DIR=news_output

TRADE_CONTEXT_MODE=all
